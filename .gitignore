!backtest_results/ablation_summary.csv
!backtest_results/price_quantile_holdout.csv
!backtest_results/battery_pnl_daily.csv

# Model artifacts — only the deployed models are committed; experiments stay local.
# Older versions (price_quantile_v1, v3, lstm_attention_v1, lstm_plain_v1,
# lstm_weather_v1, best_*.h5) are intentionally not tracked.
model_checkpoints/*
!model_checkpoints/lstm_quantile_v1/
!model_checkpoints/price_quantile_v4/
